# ── Required ───────────────────────────────────────────────────────────────────
# At least one of these is required for LLM scoring
ANTHROPIC_API_KEY=sk-ant-...       # Claude (fallback scorer)
GROQ_API_KEY=gsk_...               # Groq/llama-3.3-70b (primary scorer, free)

# ── Optional — search APIs (unlock LinkedIn stealth signals) ────────────────────
# Add any one of these and LinkedIn stealth discovery activates automatically.
# Recommended: Serper or Google CSE (most reliable for site:linkedin.com queries)
SERPER_API_KEY=                    # serper.dev — 2500 free/month (https://serper.dev)
BRAVE_API_KEY=                     # Brave Search — free tier (https://api.search.brave.com)
GOOGLE_CSE_API_KEY=                # Google Cloud API key — 100 free/day (console.cloud.google.com)
GOOGLE_CSE_CX=                     # Google CSE ID — create at programmablesearchengine.google.com
TAVILY_API_KEY=                    # Tavily AI Search — 1000 free/month (https://tavily.com)

# ── Optional ───────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...           # Firecrawl (enables structured extraction)
GITHUB_TOKEN=ghp_...               # GitHub token (raises rate limit 60→5000/hr)

# ── Tuning ─────────────────────────────────────────────────────────────────────
MIN_SCORE_THRESHOLD=40             # Minimum score to include in report (0-100); rule-based floor is ~30
TOP_N_IN_DIGEST=15                 # Max founders shown in top section of report
REPORTS_DIR=reports                # Directory for markdown reports

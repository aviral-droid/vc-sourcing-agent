# ── Required ───────────────────────────────────────────────────────────────────
# At least one of these is required for LLM scoring
ANTHROPIC_API_KEY=sk-ant-...       # Claude (fallback scorer)
GROQ_API_KEY=gsk_...               # Groq/llama-3.3-70b (primary scorer, free)

# ── Optional ───────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...           # Firecrawl (enables structured extraction)
GITHUB_TOKEN=ghp_...               # GitHub token (raises rate limit 60→5000/hr)

# ── Tuning ─────────────────────────────────────────────────────────────────────
MIN_SCORE_THRESHOLD=55             # Minimum score to include in report (0-100)
TOP_N_IN_DIGEST=15                 # Max founders shown in top section of report
REPORTS_DIR=reports                # Directory for markdown reports
